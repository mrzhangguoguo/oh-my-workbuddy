{
  "name": "oh-my-workbuddy",
  "version": "0.3.0",
  "type": "module",
  "description": "An oh-my-codex-style skill pack for WorkBuddy: catalog-driven skills, dual-scope install, zero runtime.",
  "bin": {
    "omw": "omw"
  },
  "scripts": {
    "setup": "node lib/cli.js setup",
    "sync": "node lib/cli.js sync",
    "doctor": "node lib/cli.js doctor",
    "list": "node lib/cli.js list",
    "validate": "node validate_frontmatter.js",
    "verify-catalog": "node scripts/generate-catalog.js --check",
    "test": "node --test lib/__tests__/*.test.js",
    "generate-catalog": "node scripts/generate-catalog.js",
    "generate-skill-rules": "node scripts/generate-skill-rules.js",
    "verify-skill-rules": "node scripts/generate-skill-rules.js --check"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0"
  },
  "license": "MIT"
}
